{
  "kind": "collectionType",
  "collectionName": "faqs",
  "info": {
    "singularName": "faq",
    "pluralName": "faqs",
    "displayName": "FAQ",
    "description": "Questions fr\u00e9quentes"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "question": { "type": "string", "required": true, "maxLength": 500 },
    "answer": { "type": "richtext", "required": true },
    "category": {
      "type": "enumeration",
      "enum": ["general", "livraison", "consigne", "paiement", "btob"],
      "default": "general",
      "required": true
    },
    "order": { "type": "integer", "default": 0, "required": true }
  }
}

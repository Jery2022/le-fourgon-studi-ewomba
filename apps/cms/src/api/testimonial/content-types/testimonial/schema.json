{
  "kind": "collectionType",
  "collectionName": "testimonials",
  "info": {
    "singularName": "testimonial",
    "pluralName": "testimonials",
    "displayName": "T\u00e9moignage",
    "description": "T\u00e9moignages clients BtoC et BtoB"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "name": { "type": "string", "required": true, "maxLength": 100 },
    "role": { "type": "string", "maxLength": 100 },
    "company": { "type": "string", "maxLength": 200 },
    "content": { "type": "text", "required": true, "maxLength": 1000 },
    "rating": { "type": "integer", "required": true, "min": 1, "max": 5, "default": 5 },
    "avatar": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "isBtoB": { "type": "boolean", "default": false, "required": true }
  }
}

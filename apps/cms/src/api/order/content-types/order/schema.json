{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Commande",
    "description": "Commandes clients Le Fourgon"
  },
  "options": { "draftAndPublish": false },
  "attributes": {
    "orderNumber": {
      "type": "string",
      "required": true,
      "unique": true,
      "maxLength": 20
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "confirmed", "preparing", "shipped", "delivered", "cancelled", "refunded"],
      "default": "pending",
      "required": true
    },
    "items": {
      "type": "json",
      "required": true
    },
    "subtotal": { "type": "integer", "required": true, "min": 0 },
    "totalDeposit": { "type": "integer", "required": true, "min": 0 },
    "deliveryFee": { "type": "integer", "required": true, "min": 0 },
    "promoDiscount": { "type": "integer", "default": 0, "min": 0 },
    "total": { "type": "integer", "required": true, "min": 0 },
    "deliveryAddress": { "type": "json", "required": true },
    "deliveryDate": { "type": "date" },
    "deliverySlot": { "type": "string" },
    "collectionPoint": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::collection-point.collection-point"
    },
    "paymentIntentId": { "type": "string", "maxLength": 255 },
    "stripeSessionId": { "type": "string", "maxLength": 255 },
    "customer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "promoCode": { "type": "string", "maxLength": 50 },
    "notes": { "type": "text", "maxLength": 1000 }
  }
}

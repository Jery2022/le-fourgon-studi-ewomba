{
  "kind": "collectionType",
  "collectionName": "authors",
  "info": {
    "singularName": "author",
    "pluralName": "authors",
    "displayName": "Auteur",
    "description": "Auteurs du blog"
  },
  "options": { "draftAndPublish": false },
  "attributes": {
    "name": { "type": "string", "required": true, "maxLength": 100 },
    "bio": { "type": "text", "maxLength": 500 },
    "avatar": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::article.article",
      "mappedBy": "author"
    }
  }
}

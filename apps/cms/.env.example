# ══════════════════════════════════════════════
#  Variables d'environnement — Strapi CMS
#  Copier ce fichier en .env et remplir les valeurs
# ══════════════════════════════════════════════

# ── Serveur ──
HOST=0.0.0.0
PORT=1337
PUBLIC_URL=http://localhost:1337

# ── Sécurité (générer avec: openssl rand -base64 32) ──
APP_KEYS=key1_change_me,key2_change_me
API_TOKEN_SALT=change_me_api_token_salt
ADMIN_JWT_SECRET=change_me_admin_jwt_secret
TRANSFER_TOKEN_SALT=change_me_transfer_token_salt
JWT_SECRET=change_me_jwt_secret

# ── Base de données PostgreSQL ──
DATABASE_CLIENT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=lefourgon_db
DATABASE_USERNAME=lefourgon
DATABASE_PASSWORD=your_secure_password_here
DATABASE_SSL=false

# ── OU SQLite (développement rapide) ──
# DATABASE_CLIENT=sqlite
# DATABASE_FILENAME=.tmp/data.db

# ── Frontend (CORS) ──
FRONTEND_URL=http://localhost:3000

# ── Cloudinary (optionnel, pour les médias) ──
# CLOUDINARY_NAME=xxx
# CLOUDINARY_KEY=xxx
# CLOUDINARY_SECRET=xxx

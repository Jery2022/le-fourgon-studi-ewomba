# ══════════════════════════════════════════════
#  Variables d'environnement — Strapi CMS
#  Copier ce fichier en .env et remplir les valeurs
# ══════════════════════════════════════════════

# ── Serveur ──
HOST=0.0.0.0
PORT=1337
PUBLIC_URL=http://localhost:1337

# ── Sécurité (générer avec: openssl rand -base64 32) ──
APP_KEYS=xxx,xxx
API_TOKEN_SALT=xxx
ADMIN_JWT_SECRET=xxx
TRANSFER_TOKEN_SALT=xxx
JWT_SECRET=xxx

# ── Base de données PostgreSQL ──
DATABASE_CLIENT=postgres
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=lefourgon_db
DATABASE_USERNAME=lefourgon
DATABASE_PASSWORD=mot de passe
DATABASE_SSL=false

# ── OU SQLite (développement rapide) ──
# DATABASE_CLIENT=sqlite
# DATABASE_FILENAME=.tmp/data.db

# ── Frontend (CORS) ──
FRONTEND_URL=http://localhost:3000

# ── Cloudinary (optionnel, pour les médias) ──
# CLOUDINARY_NAME=xxx
# CLOUDINARY_KEY=xxx
# CLOUDINARY_SECRET=xxx
UDINARY_SECRET=xxx
